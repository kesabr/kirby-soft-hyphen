{
  "name": "kesabr/kirby-soft-hyphen",
  "description": "Helper to use a designated character in the panel to create a soft hyphen in the frontend",
  "version": "1.0.0",
  "type": "kirby-plugin",
  "license": "MIT",
  "authors": [
    {
      "name": "Kenan Brunner"
    }
  ],
  "require": {
    "php": ">=8.1.0",
    "getkirby/cms": "^4.0 || ^5.0",
    "getkirby/composer-installer": "^1.1"
  },
  "extra": {
    "installer-name": "kirby-soft-hyphen",
    "kirby-cms-path": false
  },
  "config": {
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  }
}
